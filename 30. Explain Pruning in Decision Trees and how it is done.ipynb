   "source": [
    "🔴 Unpruned Tree (Overfitting)\n",
    "                Root\n",
    "               /    \\\n",
    "          Age < 30   Age ≥ 30\n",
    "           /             \\\n",
    "      Income < 50k      Income > 80k\n",
    "       /     \\             /      \\\n",
    "   Yes      No         Yes       No\n",
    "   /                     \\\n",
    "Credit=Low           Married=Yes\n",
    "  /    \\               /      \\\n",
    "Yes    No           Yes       No\n",
    "\n",
    "❌ Problems:\n",
    "\n",
    "Too many splits\n",
    "Learns noise\n",
    "Very deep tree\n",
    "Poor generalization\n",
    "🟢 Pruned Tree (Better Generalization)\n",
    "            Root\n",
    "           /    \\\n",
    "     Age < 30   Age ≥ 30\n",
    "       /             \\\n",
    "     Yes             No\n",
    "\n",
    "✔️ Benefits:\n",
    "\n",
    "Simpler\n",
    "Less noise\n",
    "Better on unseen data\n",
    "🎯 Key Insight\n",
    "\n",
    "👉 Pruning removes branches that don’t add significant predictive power."
   ]
  },
